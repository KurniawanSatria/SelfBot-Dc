# Discord Token(s)
# For single account:
TOKEN=your_discord_token_here

# For multiple accounts (comma-separated):
# TOKEN=token1,token2,token3

# Discord Server & Channel IDs
AUTO_JOIN_GUILD_ID=your_guild_id_here
AUTO_JOIN_CHANNEL_ID=your_voice_channel_id_here

# Spotify Connection ID(s)
# For single account:
SPOTIFY_CONNECTION_ID=your_spotify_connection_id_here

# For multiple accounts (comma-separated, matches TOKEN order):
# SPOTIFY_CONNECTION_IDS=connection_id1,connection_id2,connection_id3

# How to get your Discord Token:
# 1. Open Discord in browser (discord.com/app)
# 2. Press F12 to open DevTools
# 3. Go to Console tab
# 4. Paste: (webpackChunkdiscord_app.push([[''],{},e=>{m=[];for(let c in e.c)m.push(e.c[c])}]),m).find(m=>m?.exports?.default?.getToken!==void 0).exports.default.getToken()
# 5. Copy the token (without quotes)

# How to get Spotify Connection ID:
# 1. Open Discord in browser with DevTools (F12)
# 2. Go to Network tab
# 3. Filter: "spotify"
# 4. Navigate to User Settings > Connections > Spotify
# 5. Look for requests to: /users/@me/connections/spotify/{connection_id}/access-token
# 6. Copy the connection_id from the URL

# How to get Guild ID & Channel ID:
# 1. Enable Developer Mode in Discord (Settings > Advanced > Developer Mode)
# 2. Right-click on server name → Copy Server ID (GUILD_ID)
# 3. Right-click on voice channel → Copy Channel ID (CHANNEL_ID)
